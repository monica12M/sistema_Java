
import java.util.ArrayList;
import java.util.List;

class Venta {
    private String fecha;
    private String producto;
    private int cantidad;
    private double precioUnitario;

    public Venta(String fecha, String producto, int cantidad, double precioUnitario) {
        this.fecha = fecha;
        this.producto = producto;
        this.cantidad = cantidad;
        this.precioUnitario = precioUnitario;
    }

    public double getTotal() {
        return cantidad * precioUnitario;
    }

    @Override
    public String toString() {
        return String.format("%-12s %-15s %-10d %-12.2f %-12.2f",
                fecha, producto, cantidad, precioUnitario, getTotal());
    }
}

public class TablaVentas {
    public static void main(String[] args) {
        List<Venta> ventas = new ArrayList<>();

        // Ejemplo de registros
        ventas.add(new Venta("2026-03-21", "Laptop", 2, 15000));
        ventas.add(new Venta("2026-03-21", "Mouse", 5, 250));
        ventas.add(new Venta("2026-03-22", "Teclado", 3, 800));

        // Encabezado de la tabla
        System.out.printf("%-12s %-15s %-10s %-12s %-12s%n",
                "Fecha", "Producto", "Cantidad", "PrecioUnit", "Total");

        // Mostrar cada venta
        for (Venta v : ventas) {
            System.out.println(v);
        }

        // Calcular total general
        double totalGeneral = ventas.stream().mapToDouble(Venta::getTotal).sum();
        System.out.println("\nTotal General: " + totalGeneral);
}

